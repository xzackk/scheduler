# Copy this file to .env and fill in your values:  cp .env.example .env
# (.env is gitignored — never commit real secrets)

# Your GHCR image (lowercase GitHub username/org)
IMAGE=ghcr.io/your-github-username/scheduler:latest

# Cloudflare Tunnel token (from the Zero Trust dashboard, see README)
TUNNEL_TOKEN=paste-your-cloudflare-tunnel-token-here
